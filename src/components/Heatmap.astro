---
import { getCollection } from "astro:content";
import dayjs from "dayjs";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

// Generate 52-week calendar up to today
const today = dayjs();
const oneYearAgo = today.subtract(51, 'week').startOf('week');

// Count posts per day
const postCounts = new Map<string, number>();
allPosts.forEach(post => {
  const dateStr = dayjs(post.data.pubDatetime).format("YYYY-MM-DD");
  postCounts.set(dateStr, (postCounts.get(dateStr) || 0) + 1);
});

const weeks = [];
let currentDate = oneYearAgo;

for (let w = 0; w < 52; w++) {
  const days = [];
  for (let d = 0; d < 7; d++) {
    const dateStr = currentDate.format("YYYY-MM-DD");
    days.push({
      date: dateStr,
      count: postCounts.get(dateStr) || 0
    });
    currentDate = currentDate.add(1, 'day');
  }
  weeks.push(days);
}

const totalPosts = allPosts.length;

const getColorClass = (count: number) => {
  if (count === 0) return "bg-border/20";
  if (count === 1) return "bg-accent/30";
  if (count === 2) return "bg-accent/60";
  return "bg-accent";
};
---

<div class="rounded-2xl border border-border/40 bg-background/60 backdrop-blur-sm p-5 shadow-sm ring-1 ring-border/10">
  <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider opacity-60">Activity</h3>
  
  <div class="overflow-x-auto pb-1">
    <div class="flex gap-[3px] min-w-max">
      {weeks.map(week => (
        <div class="flex flex-col gap-[3px]">
          {week.map(day => (
            <div 
              class={`w-[10px] h-[10px] rounded-[2px] transition-colors ${getColorClass(day.count)}`}
              title={`${day.count} posts on ${day.date}`}
            ></div>
          ))}
        </div>
      ))}
    </div>
  </div>
  
  <div class="mt-3 flex items-center justify-between text-[10px] opacity-60">
    <span>{totalPosts} posts this year</span>
    <div class="flex items-center gap-1">
      <span>Less</span>
      <div class="flex gap-[3px]">
        <div class="w-[10px] h-[10px] rounded-[2px] bg-border/20"></div>
        <div class="w-[10px] h-[10px] rounded-[2px] bg-accent/30"></div>
        <div class="w-[10px] h-[10px] rounded-[2px] bg-accent/60"></div>
        <div class="w-[10px] h-[10px] rounded-[2px] bg-accent"></div>
      </div>
      <span>More</span>
    </div>
  </div>
</div>
