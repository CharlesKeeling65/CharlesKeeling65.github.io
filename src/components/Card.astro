---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ...props } = data;
---

<li class="my-6 group rounded-2xl border border-border/30 bg-background/40 backdrop-blur-md p-5 sm:p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-accent/40 hover:bg-accent/5">
  <a
    href={getPath(id, filePath)}
    class:list={[
      "inline-block text-xl font-bold text-accent transition-colors mb-1",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>
  </a>
  <div class="opacity-80 mb-3">
    <Datetime {...props} />
  </div>
  <p class="leading-relaxed opacity-90">{description}</p>
</li>
